{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IncidentReport",
  "type": "object",
  "required": [
    "incident_id",
    "title",
    "executive_summary",
    "severity",
    "attack_family",
    "scope",
    "confirmed_findings",
    "suspected_findings",
    "business_impact",
    "affected_assets",
    "timeline_summary",
    "recommended_immediate_actions"
  ],
  "properties": {
    "incident_id": { "type": "string" },
    "title": { "type": "string" },
    "executive_summary": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "attack_family": { "type": "string" },
    "scope": { "type": "array", "items": { "type": "string" } },
    "confirmed_findings": { "type": "array", "items": { "type": "string" } },
    "suspected_findings": { "type": "array", "items": { "type": "string" } },
    "business_impact": { "type": "string" },
    "affected_assets": { "type": "array", "items": { "type": "string" } },
    "timeline_summary": { "type": "array", "items": { "type": "string" } },
    "recommended_immediate_actions": { "type": "array", "items": { "type": "string" } }
  }
}

