{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RemediationPlan",
  "type": "object",
  "required": [
    "incident_id",
    "immediate_actions",
    "short_term_actions",
    "long_term_actions",
    "reindex_recommendation",
    "monitoring_recommendations",
    "rollback_risk_notes"
  ],
  "properties": {
    "incident_id": { "type": "string" },
    "immediate_actions": { "$ref": "#/$defs/actions" },
    "short_term_actions": { "$ref": "#/$defs/actions" },
    "long_term_actions": { "$ref": "#/$defs/actions" },
    "reindex_recommendation": { "type": "string" },
    "monitoring_recommendations": { "type": "array", "items": { "type": "string" } },
    "rollback_risk_notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "priority", "reason", "requires_human_approval"],
        "properties": {
          "action": { "type": "string" },
          "priority": { "type": "integer", "minimum": 1 },
          "reason": { "type": "string" },
          "requires_human_approval": { "type": "boolean" }
        }
      }
    }
  }
}

