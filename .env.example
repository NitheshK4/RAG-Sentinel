# ── RAG Sentinel — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values.
# All variables are optional — the app runs in demo mode by default.

# ── LLM Configuration ────────────────────────────────────────────
# Your Gemini API key. If unset, the app runs in DEMO mode with mock data.
GEMINI_API_KEY=

# Gemini model to use for structured JSON generation.
# Default: gemini-2.0-flash
LLM_MODEL=gemini-2.0-flash

# Temperature for LLM generation (0.0 = deterministic, 1.0 = creative).
# Default: 0.1 (low temperature for consistent, structured output)
LLM_TEMPERATURE=0.1

# ── Rate Limiting ────────────────────────────────────────────────
# Maximum requests per minute per IP address.
# Default: 120
RATE_LIMIT_RPM=120

# Burst allowance above the RPM limit.
# Default: 20
RATE_LIMIT_BURST=20
